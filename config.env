# Jetson AGX Orin Flash Kit - configuration
#
# Sourced by scripts/flash.sh. Override any value by exporting it before
# running, or by editing this file.

# JetPack version. 5.1.5 -> L4T 35.6.x (Ubuntu 20.04 rootfs).
JETPACK_VERSION="${JETPACK_VERSION:-5.1.5}"

# SDK Manager target identifier. JETSON_AGX_ORIN_TARGETS covers the AGX Orin
# Devkit (P3701-0005), 32GB, and Industrial - SDK Manager autodetects the
# specific SOM during flash.
SDKM_TARGET="${SDKM_TARGET:-JETSON_AGX_ORIN_TARGETS}"

# Docker image for SDK Manager. Auto-detected by scripts/flash.sh if empty or
# absent on the host. Set explicitly when multiple sdkmanager images coexist.
SDKM_IMAGE="${SDKM_IMAGE:-}"
